{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Particle-Academy/holy-sheet/skills/holy-sheet.schema.json",
  "title": "Holy Sheet workbook schema",
  "description": "Input format for HolySheet\\Agent::write(). Describes a multi-sheet xlsx workbook agentically. v0.2.0 supports scalar values, formulas (cached), and multiple sheets. Styles, formats, comments, merges land in subsequent minors.",
  "type": "object",
  "required": ["sheets"],
  "additionalProperties": false,
  "properties": {
    "sheets": {
      "type": "array",
      "minItems": 1,
      "description": "One or more sheets. The first sheet is shown when the file opens.",
      "items": { "$ref": "#/definitions/Sheet" }
    },
    "meta": {
      "type": "object",
      "description": "Optional workbook metadata surfaced in Excel's File → Info pane.",
      "properties": {
        "creator": { "type": "string" },
        "created": { "type": "string", "description": "ISO-8601 datetime. Defaults to now()." }
      },
      "additionalProperties": true
    }
  },
  "definitions": {
    "Sheet": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "oneOf": [
        { "required": ["columns", "rows"], "description": "Row-oriented (agent-ergonomic)." },
        { "required": ["cells"], "description": "Sparse A1-keyed map (fancy-sheets passthrough)." }
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 31,
          "description": "Tab label in Excel. Excel limits to 31 chars and forbids /\\?*[]:"
        },
        "columns": {
          "type": "array",
          "items": { "$ref": "#/definitions/Column" },
          "description": "When present, the first row is the header row. Column types are applied to every row in that column."
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "description": "One row of cell values, in column order. Use null for missing values.",
            "items": { "$ref": "#/definitions/CellValue" }
          }
        },
        "cells": {
          "type": "object",
          "description": "Sparse A1-keyed map. Use this shape when exporting from <Spreadsheet>.",
          "additionalProperties": { "$ref": "#/definitions/CellData" },
          "patternProperties": {
            "^[A-Z]+[1-9][0-9]*$": { "$ref": "#/definitions/CellData" }
          }
        },
        "totals": {
          "type": "object",
          "description": "Symbolic aggregations appended below the data. Key = column header; value = aggregation. Lands in 0.7.",
          "additionalProperties": {
            "type": "string",
            "enum": ["sum", "avg", "count", "min", "max"]
          }
        },
        "theme": {
          "type": "string",
          "enum": ["default", "minimal", "plain", "business"],
          "default": "default",
          "description": "Pre-baked style preset. Lands in 0.3."
        },
        "mergedRegions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["start", "end"],
            "properties": {
              "start": { "type": "string", "description": "A1 ref of top-left." },
              "end": { "type": "string", "description": "A1 ref of bottom-right." }
            }
          },
          "description": "Cells to merge. Lands in 0.5."
        },
        "columnWidths": {
          "type": "object",
          "description": "Override widths in pixels. Keys are 0-based column indexes. Lands in 0.5.",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "frozenRows": { "type": "integer", "minimum": 0, "description": "Lands in 0.5." },
        "frozenCols": { "type": "integer", "minimum": 0, "description": "Lands in 0.5." }
      }
    },
    "Column": {
      "type": "object",
      "required": ["header"],
      "additionalProperties": false,
      "properties": {
        "header": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["auto", "string", "number", "integer", "boolean", "date", "datetime", "currency", "percent", "formula"],
          "default": "auto",
          "description": "Cell type applied to every value in this column. 'auto' infers per cell."
        },
        "currency": {
          "type": "string",
          "description": "ISO-4217 code (USD, EUR, JPY, ...) when type=currency. Defaults to config('holy-sheet.locale')."
        },
        "decimals": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "description": "Display decimals for number/currency/percent. Default 2 for currency, 1 for percent, 0 for integer, none for number."
        },
        "format": {
          "type": "string",
          "description": "Custom Excel number format string. Overrides type-derived format. Power-user escape hatch."
        },
        "width": { "type": "number", "minimum": 0, "description": "Column width in pixels. Same as columnWidths but per-column." }
      }
    },
    "CellValue": {
      "description": "A primitive value, null, or an object {value, formula, format, comment} for per-cell control.",
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        { "$ref": "#/definitions/CellData" }
      ]
    },
    "CellData": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": {
          "description": "Raw cell value.",
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "formula": {
          "type": "string",
          "description": "Formula without leading '='. e.g. 'SUM(A1:A10)' or 'Sheet2!B5+1'."
        },
        "computedValue": {
          "description": "Cached value from a previous evaluation. When present, Excel shows it without recomputing on open.",
          "oneOf": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }, { "type": "null" }]
        },
        "format": { "$ref": "#/definitions/CellFormat" },
        "comment": { "$ref": "#/definitions/CellComment" }
      }
    },
    "CellFormat": {
      "type": "object",
      "description": "Per-cell format. Lands in 0.3.",
      "additionalProperties": false,
      "properties": {
        "bold": { "type": "boolean" },
        "italic": { "type": "boolean" },
        "textAlign": { "type": "string", "enum": ["left", "center", "right"] },
        "displayFormat": {
          "type": "string",
          "enum": ["auto", "text", "number", "date", "datetime", "percentage", "currency"]
        },
        "decimals": { "type": "integer", "minimum": 0, "maximum": 10 },
        "color": { "type": "string", "description": "Hex color (#RRGGBB) for text." },
        "backgroundColor": { "type": "string", "description": "Hex color for cell fill." },
        "fontSize": { "type": "integer", "minimum": 6, "maximum": 72 },
        "borderTop": { "type": "string" },
        "borderRight": { "type": "string" },
        "borderBottom": { "type": "string" },
        "borderLeft": { "type": "string" }
      }
    },
    "CellComment": {
      "type": "object",
      "description": "Lands in 0.6.",
      "required": ["text"],
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string" },
        "author": { "type": "string" },
        "color": { "type": "string", "description": "Hex color for the corner triangle indicator." }
      }
    }
  }
}
